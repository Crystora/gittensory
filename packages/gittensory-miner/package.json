{
  "name": "@jsonbored/gittensory-miner",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Foundation CLI for the local Gittensory miner runtime.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSONbored/gittensory.git",
    "directory": "packages/gittensory-miner"
  },
  "homepage": "https://github.com/JSONbored/gittensory#readme",
  "bugs": {
    "url": "https://github.com/JSONbored/gittensory/issues"
  },
  "keywords": [
    "gittensor",
    "gittensory",
    "miner",
    "cli",
    "agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "gittensory-miner": "bin/gittensory-miner.js"
  },
  "files": [
    "bin",
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node --check bin/gittensory-miner.js && node --check lib/cli.js && node --check lib/update-check.js && node --check lib/opportunity-fanout.js",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\""
  },
  "dependencies": {
    "@jsonbored/gittensory-engine": "0.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
